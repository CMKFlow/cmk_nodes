import { app } from "../../../scripts/app.js";

const NODE_CLASSES = ["CMK_FaceProcess", "CMKFaceProcess"];
const NODE_DISPLAY = "CMK Face Process";
const CREATE_FACE_CLASS = "CMKPipeCreateFaceProcess";
const CREATE_FACE_DISPLAY = "CMK Pipe Create Face Process";

// Must match CMK_FaceProcess widget serialization order.
const FULL_WIDGET_ORDER = [
  "process_mode",
  "face_enable",
  "detect_model",
  "detect_bbox_threshold",
  "detect_bbox_dilation",
  "detect_crop_factor",
  "detect_drop_size",
  "restore_model",
  "restore_facedetection",
  "restore_visibility",
  "restore_codeformer_weight",
  "select_face_selection",
  "select_sort_by",
  "select_reverse_order",
  "select_take_start",
  "select_take_count",
  "detail_guide_size",
  "detail_guide_size_for",
  "detail_max_size",
  "detail_denoise",
  "detail_noise_mask",
  "detail_force_inpaint",
  "detail_paste_feather",
];

const PROCESS_WIDGETS = ["process_mode", "face_enable"];

const DETECT_WIDGETS = [
  "detect_model",
  "detect_bbox_threshold",
  "detect_bbox_dilation",
  "detect_crop_factor",
  "detect_drop_size",
];

const RESTORE_WIDGETS = [
  "restore_model",
  "restore_facedetection",
  "restore_visibility",
  "restore_codeformer_weight",
];

const SELECT_WIDGETS = [
  "select_face_selection",
  "select_sort_by",
  "select_reverse_order",
  "select_take_start",
  "select_take_count",
];

const DETAILER_WIDGETS = [
  "detail_guide_size",
  "detail_guide_size_for",
  "detail_max_size",
  "detail_denoise",
  "detail_noise_mask",
  "detail_force_inpaint",
  "detail_paste_feather",
];

function displayLabelForName(name) {
  const explicit = {
    process_mode: "Process Mode",
    face_enable: "Face Enable",
    detect_model: "model",
    detect_bbox_threshold: "bbox threshold",
    detect_bbox_dilation: "bbox dilation",
    detect_crop_factor: "crop factor",
    detect_drop_size: "drop size",
    restore_model: "model",
    restore_facedetection: "facedetection",
    restore_visibility: "visibility",
    restore_codeformer_weight: "codeformer weight",
    select_face_selection: "face selection",
    select_sort_by: "sort by",
    select_reverse_order: "reverse order",
    select_take_start: "take start",
    select_take_count: "take count",
    detail_guide_size: "guide size",
    detail_guide_size_for: "guide size for",
    detail_max_size: "max size",
    detail_denoise: "denoise",
    detail_noise_mask: "noise mask",
    detail_force_inpaint: "force inpaint",
    detail_paste_feather: "paste feather",
  };
  return explicit[name] ?? name.replace(/_/g, " ");
}

function applyDisplayLabel(widget) {
  if (!widget?.name) return;
  widget.label = displayLabelForName(widget.name);
}

function widgetByName(list, name) {
  return list?.find((widget) => widget?.name === name);
}

function normalizeModeValue(value) {
  // Older workflow states may still contain "bypass". Bypass is now expressed
  // by Face Enable = false, so the UI falls back to restore for configuration.
  if (value === "detailer") return "detailer";
  return "restore";
}

function wantedWidgetsForMode(mode) {
  mode = normalizeModeValue(mode);
  if (mode === "restore") {
    return [...PROCESS_WIDGETS, ...DETECT_WIDGETS, ...RESTORE_WIDGETS, ...SELECT_WIDGETS];
  }
  if (mode === "detailer") {
    return [...PROCESS_WIDGETS, ...DETECT_WIDGETS, ...SELECT_WIDGETS, ...DETAILER_WIDGETS];
  }
  return [...PROCESS_WIDGETS, ...DETECT_WIDGETS, ...RESTORE_WIDGETS, ...SELECT_WIDGETS];
}

function readWidgetValue(node, name) {
  const visible = widgetByName(node.widgets, name);
  if (visible) return visible.value;

  const saved = node.properties?.cmk_face_process_values;
  if (saved && Object.prototype.hasOwnProperty.call(saved, name)) return saved[name];

  const original = node._cmk_face_process_original_widgets?.get(name);
  return original?.value;
}

function saveAllWidgetValues(node) {
  node.properties ??= {};
  node.properties.cmk_face_process_values ??= {};

  for (const name of FULL_WIDGET_ORDER) {
    const value = readWidgetValue(node, name);
    if (value !== undefined) node.properties.cmk_face_process_values[name] = value;
  }
}

function restoreWidgetValue(node, widget) {
  if (!widget?.name) return;
  const saved = node.properties?.cmk_face_process_values?.[widget.name];
  if (saved !== undefined) widget.value = saved;
}

function ensureLayoutStore(node) {
  node.properties ??= {};
  node.properties.cmk_face_process_layout ??= { width: null, height: null };
  return node.properties.cmk_face_process_layout;
}

function rememberCurrentSize(node) {
  if (!Array.isArray(node.size)) return;
  const layout = ensureLayoutStore(node);
  layout.width = node.size[0] || layout.width;
  layout.height = Math.max(layout.height || 0, node.size[1] || 0) || layout.height;
}

function applyAnchoredSize(node, previousSize) {
  const layout = ensureLayoutStore(node);
  const width = layout.width || previousSize?.[0] || node.size?.[0];

  let computedHeight = null;
  const computed = node.computeSize?.();
  if (Array.isArray(computed) && Number.isFinite(computed[1])) computedHeight = computed[1];

  const height = Math.max(
    layout.height || 0,
    previousSize?.[1] || 0,
    computedHeight || 0,
    node.size?.[1] || 0
  );

  if (height) layout.height = height;
  if (width && layout.height) node.size = [width, layout.height];
}

function queueRebuild(node) {
  if (node._cmk_face_process_rebuild_queued) return;
  node._cmk_face_process_rebuild_queued = true;
  requestAnimationFrame(() => {
    node._cmk_face_process_rebuild_queued = false;
    rebuildWidgets(node);
  });
}

function attachValueWatcher(node, widget) {
  applyDisplayLabel(widget);
  if (!widget || widget._cmk_face_process_watched) return;
  widget._cmk_face_process_watched = true;

  const originalCallback = widget.callback;
  widget.callback = function(value, canvas, n, pos, event) {
    const result = originalCallback?.apply(this, arguments);
    saveAllWidgetValues(node);
    if (widget.name === "process_mode") queueRebuild(node);
    return result;
  };

  if (widget.name !== "process_mode") return;

  let internalValue = widget.value;
  try {
    Object.defineProperty(widget, "value", {
      configurable: true,
      enumerable: true,
      get() {
        return internalValue;
      },
      set(value) {
        const changed = internalValue !== value;
        internalValue = value;
        if (changed) {
          node.properties ??= {};
          node.properties.cmk_face_process_values ??= {};
          node.properties.cmk_face_process_values.process_mode = value;
          queueRebuild(node);
        }
      },
    });
    widget.value = internalValue;
  } catch (_) {
    // Some Comfy builds lock widget fields. Callback/onDraw fallback remains active.
  }
}

function rebuildWidgets(node) {
  if (!node._cmk_face_process_original_widgets) return;

  saveAllWidgetValues(node);
  rememberCurrentSize(node);

  const rawMode = readWidgetValue(node, "process_mode");
  const mode = normalizeModeValue(rawMode);
  if (rawMode === "bypass") {
    node.properties ??= {};
    node.properties.cmk_face_process_values ??= {};
    node.properties.cmk_face_process_values.process_mode = "restore";
    node.properties.cmk_face_process_values.face_enable = false;
  }
  const wanted = wantedWidgetsForMode(mode);
  const nextWidgets = [];

  for (const name of wanted) {
    const widget = node._cmk_face_process_original_widgets.get(name);
    if (!widget) continue;
    restoreWidgetValue(node, widget);
    attachValueWatcher(node, widget);
    applyDisplayLabel(widget);
    nextWidgets.push(widget);
  }

  const previousSize = Array.isArray(node.size) ? [node.size[0], node.size[1]] : null;
  node.widgets = nextWidgets;
  node._cmk_face_process_visible_mode = mode;
  applyAnchoredSize(node, previousSize);
  app.graph?.setDirtyCanvas?.(true, true);
}

function patchFaceProcessNode(nodeType) {
  if (nodeType.prototype._cmk_face_process_rebuild_patched) return;
  nodeType.prototype._cmk_face_process_rebuild_patched = true;

  const originalOnNodeCreated = nodeType.prototype.onNodeCreated;
  nodeType.prototype.onNodeCreated = function() {
    originalOnNodeCreated?.apply(this, arguments);

    this.properties ??= {};
    this.properties.cmk_face_process_values ??= {};
    this._cmk_face_process_original_widgets = new Map();

    for (const widget of this.widgets ?? []) {
      if (!widget?.name) continue;
      this._cmk_face_process_original_widgets.set(widget.name, widget);
      if (FULL_WIDGET_ORDER.includes(widget.name) && this.properties.cmk_face_process_values[widget.name] === undefined) {
        this.properties.cmk_face_process_values[widget.name] = widget.value;
      }
      attachValueWatcher(this, widget);
    }

    queueRebuild(this);
  };

  const originalOnConfigure = nodeType.prototype.onConfigure;
  nodeType.prototype.onConfigure = function(info) {
    originalOnConfigure?.apply(this, arguments);

    this.properties ??= {};
    this.properties.cmk_face_process_values ??= {};

    // Comfy serializes widgets_values in widget order.
    if (Array.isArray(info?.widgets_values)) {
      for (let i = 0; i < FULL_WIDGET_ORDER.length; i++) {
        if (info.widgets_values[i] !== undefined) {
          this.properties.cmk_face_process_values[FULL_WIDGET_ORDER[i]] = info.widgets_values[i];
        }
      }
    }

    this._cmk_face_process_original_widgets ??= new Map();
    for (const widget of this.widgets ?? []) {
      if (!widget?.name) continue;
      if (!this._cmk_face_process_original_widgets.has(widget.name)) {
        this._cmk_face_process_original_widgets.set(widget.name, widget);
      }
      attachValueWatcher(this, widget);
    }

    queueRebuild(this);
  };

  const originalSerialize = nodeType.prototype.serialize;
  nodeType.prototype.serialize = function() {
    saveAllWidgetValues(this);
    const data = originalSerialize
      ? originalSerialize.apply(this, arguments)
      : LiteGraph.LGraphNode.prototype.serialize.apply(this, arguments);
    data.widgets_values = FULL_WIDGET_ORDER.map((name) => readWidgetValue(this, name));
    data.properties ??= {};
    data.properties.cmk_face_process_values = { ...(this.properties?.cmk_face_process_values ?? {}) };
    data.properties.cmk_face_process_layout = { ...(this.properties?.cmk_face_process_layout ?? {}) };
    return data;
  };

  const originalOnDrawForeground = nodeType.prototype.onDrawForeground;
  nodeType.prototype.onDrawForeground = function(ctx) {
    originalOnDrawForeground?.apply(this, arguments);
    const mode = normalizeModeValue(readWidgetValue(this, "process_mode"));
    if (mode !== this._cmk_face_process_visible_mode) queueRebuild(this);
  };
}

function patchCreateFaceProcessNode(nodeType) {
  if (nodeType.prototype._cmk_face_create_label_patched) return;
  nodeType.prototype._cmk_face_create_label_patched = true;

  const originalOnNodeCreated = nodeType.prototype.onNodeCreated;
  nodeType.prototype.onNodeCreated = function() {
    originalOnNodeCreated?.apply(this, arguments);
    const faceEnable = widgetByName(this.widgets, "face_enable");
    if (faceEnable) faceEnable.label = "Face Enable";
  };
}

app.registerExtension({
  name: "cmk.face_process.framework2.rebuild_ui",
  beforeRegisterNodeDef(nodeType, nodeData) {
    if (NODE_CLASSES.includes(nodeData?.name) || nodeData?.display_name === NODE_DISPLAY) {
      patchFaceProcessNode(nodeType);
    }
    if (nodeData?.name === CREATE_FACE_CLASS || nodeData?.display_name === CREATE_FACE_DISPLAY) {
      patchCreateFaceProcessNode(nodeType);
    }
  },
});
